# ============================================================================
# Perx Routes — environment configuration
# ============================================================================
# The DEMO runs fully WITHOUT any keys: AI uses a deterministic engine, auth
# uses a dev secret, and payouts run a clearly-labelled SANDBOX SIMULATOR.
# Real money movement is OFF until you configure live providers AND flip the
# compliance gate below. Sandbox events are never presented as live money.

# ---- Core ----
# Signs session JWTs (httpOnly cookies). SET in any real deployment.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ---- AI Concierge (optional) ----
ANTHROPIC_API_KEY=
PERX_AI_MODEL=claude-opus-4-8
PERX_FORCE_FALLBACK=false

# ---- Optional: Rewards Payouts module ----
# The core product is the welfare loop (employer -> provider, money never reaches
# the employee). Rewards payouts (employer cash bonuses to an employee's OWN
# bank/PayPal/crypto destination) are a SEPARATE, optional module. Left off, the
# default demo shows only the welfare loop — no bank/card/IBAN inputs anywhere an
# employee looks. Set true to expose the rewards UI, routes, APIs and the finance
# console. This only enables the module; live money still needs LIVE_PAYOUTS_ENABLED
# plus configured providers below.
NEXT_PUBLIC_ENABLE_REWARDS_PAYOUTS=false

# ============================================================================
# Encryption at rest (provider tokens, sensitive fields)
# ============================================================================
# AES-256-GCM. Rotation-aware: a JSON map of keyId -> base64(32 bytes).
# Generate a key:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ENCRYPTION_KEYS={"k1":"<base64-32-bytes>"}
ENCRYPTION_KEYS=
ENCRYPTION_ACTIVE_KEY_ID=k1

# ============================================================================
# Compliance master switch — LIVE PAYOUTS DEFAULT OFF
# ============================================================================
# Only set true AFTER: legal entity verified, licensed providers onboarded,
# KYC/AML + sanctions screening complete, compliance sign-off. See
# docs/provider-decision-record.md and docs/runbook.md.
LIVE_PAYOUTS_ENABLED=false

# ============================================================================
# Bank rail — provider: Wise (TransferWise) Platform / Payouts
# Albania (ALL) + EUR/USD corridors. See provider-decision-record.md.
# ============================================================================
WISE_API_TOKEN=
WISE_PROFILE_ID=
WISE_ENV=sandbox            # sandbox | live

# IBAN/BIC validation API (reputable, not regex-only). e.g. ibanapi.com / iban.com.
# When unset, a real offline ISO 7064 mod-97 + ISO 9362 BIC check is used.
IBAN_API_URL=
IBAN_API_KEY=

# ============================================================================
# PayPal rail — PayPal Payouts REST API (verified-recipient by email)
# ============================================================================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox          # sandbox | live
PAYPAL_WEBHOOK_ID=          # from the PayPal app webhook config (for signature verification)

# ============================================================================
# Crypto rail — testnet only in dev; production requires a licensed custodian.
# ============================================================================
CRYPTO_CUSTODY_API_URL=
CRYPTO_CUSTODY_API_KEY=
CRYPTO_ENV=testnet          # testnet | mainnet (mainnet requires custody + compliance)

# Internal HMAC secret for the sandbox simulator's signed settlement events.
PAYOUT_WEBHOOK_SECRET=
